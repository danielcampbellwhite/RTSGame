// Aftermath — post-apocalyptic survival game schema.
//
// Design note on persistence vs. risk:
//   • Shelter + its stored resources + equipped/stored items = PERMANENT.
//   • An Expedition holds the run's transient state; items carried in the
//     BACKPACK during a run are LOST on death and only secured on a safe
//     return. This split is the heart of the risk/reward loop.
//
// Item *definitions* (stats, recipes, loot tables) live in code (src/data),
// not the DB — only item *instances* a player owns are persisted.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum PlayerState {
  AT_SHELTER
  IN_EXPEDITION
}

enum ItemLocation {
  STORAGE // safe in the shelter
  BACKPACK // carried on the current expedition (lost on death)
}

enum EquipSlot {
  PRIMARY
  SECONDARY
  ARMOR
  HELMET
  BACKPACK
}

enum ExpeditionStatus {
  ACTIVE
  RETURNED
  DIED
}

model Player {
  id        String   @id @default(cuid())
  name      String
  createdAt DateTime @default(now())

  // Character vitals (reset to full on respawn).
  health    Int @default(100)
  maxHealth Int @default(100)
  stamina   Int @default(100)
  radiation Int @default(0)

  // Permanent progression.
  level      Int @default(1)
  xp         Int @default(0)
  reputation Int @default(0)

  // Standing with each wasteland faction: { RAIDERS: n, COLLECTIVE: n, WARDENS: n }.
  factionRep Json @default("{}")

  state PlayerState @default(AT_SHELTER)

  shelter     Shelter?
  items       ItemStack[]
  expeditions Expedition[]

  @@index([name])
}

model Shelter {
  id       String @id @default(cuid())
  playerId String @unique
  player   Player @relation(fields: [playerId], references: [id], onDelete: Cascade)

  level Int @default(1)

  // Survivors living in the shelter (starts at 1 — just you). Recruiting from
  // the wasteland raises population up to popCap; upgrade beds to raise the cap.
  population Int @default(1)
  popCap     Int @default(3)

  // Survivors assigned to gather resources (sum must be <= population).
  // Idle survivors still eat but produce nothing.
  workFood  Int @default(0)
  workWater Int @default(0)
  workScrap Int @default(0)
  workMeds  Int @default(0)

  // Permanently stored survival resources.
  food   Int @default(60)
  water  Int @default(60)
  meds   Int @default(20)
  ammo   Int @default(40)
  scrap  Int @default(30)
  fuel   Int @default(20)
  morale Int @default(80)

  // Crafting-station tiers (0 = not built yet).
  workshopLvl    Int @default(1)
  medicalLvl     Int @default(1)
  ammoBenchLvl   Int @default(0)
  weaponBenchLvl Int @default(0)

  storageCap Int      @default(240)
  lastTickAt DateTime @default(now()) // anchor for resource depletion
}

model ItemStack {
  id       String @id @default(cuid())
  playerId String
  player   Player @relation(fields: [playerId], references: [id], onDelete: Cascade)

  defKey   String // -> ITEM_DEFS[defKey] in src/data/items.ts
  quantity Int    @default(1)

  // Condition for gear; null for stackable consumables/materials.
  durability Int?

  location     ItemLocation @default(STORAGE)
  equippedSlot EquipSlot? // set when this stack is equipped

  createdAt DateTime @default(now())

  @@index([playerId, location])
}

model Expedition {
  id       String @id @default(cuid())
  playerId String
  player   Player @relation(fields: [playerId], references: [id], onDelete: Cascade)

  seed      Int // deterministic world generation for this run
  status    ExpeditionStatus @default(ACTIVE)
  condition String           @default("CLEAR") // the run's weather/threat condition

  // Position on the region grid (shelter exit = 0,0).
  posX     Int @default(0)
  posY     Int @default(0)
  distance Int @default(0) // Chebyshev distance from exit -> risk/reward scaling

  visited Json  @default("[]") // entered tile keys "x,y" (your trail)
  spotted Json  @default("[]") // tiles seen from afar via `look` (not entered)
  log     Json  @default("[]") // recent event log entries
  pending Json? // an encounter on the current tile awaiting the player's choice

  startedAt DateTime  @default(now())
  endedAt   DateTime?

  @@index([playerId, status])
}
