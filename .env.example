# PostgreSQL connection string (Vercel Postgres / Neon / Supabase)
DATABASE_URL="postgresql://user:password@localhost:5432/world_dominion?schema=public"

# Optional non-pooled connection for migrations (Neon/Vercel)
DIRECT_URL="postgresql://user:password@localhost:5432/world_dominion?schema=public"

# Shared secret that protects the /api/tick cron endpoint.
# Vercel Cron sends this automatically via the CRON_SECRET env var.
CRON_SECRET="change-me-to-a-long-random-string"
