# ── Database ──
# When the host contains "neon.tech", the app automatically uses Neon's
# serverless driver (WebSocket/HTTPS) via a Prisma driver adapter — the
# recommended setup for Vercel serverless. Use the POOLED host for DATABASE_URL
# and the DIRECT (non-pooled) host for DIRECT_URL (migrations).
DATABASE_URL="postgresql://USER:PASSWORD@EP-xxxx-pooler.REGION.aws.neon.tech/neondb?sslmode=require"
DIRECT_URL="postgresql://USER:PASSWORD@EP-xxxx.REGION.aws.neon.tech/neondb?sslmode=require"

# Shared secret that protects the /api/tick cron endpoint.
# Vercel Cron sends this automatically via the CRON_SECRET env var.
CRON_SECRET="change-me-to-a-long-random-string"
